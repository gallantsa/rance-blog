# .gitignore - common ignores for Python projects and editors
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
pip-wheel-metadata/
wheel/

# Virtual environments
venv/
env/
.env/
.venv/
ENV/
venv.bak/
.python-version

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~
*.tmp
*.bak

# macOS
.DS_Store

# Logs and databases
*.log
*.sqlite3
*.db
*.sqlite

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Type checkers / caches
.mypy_cache/
.pyre/

# Jupyter
.ipynb_checkpoints/

# Node/npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Others
celerybeat-schedule


